# Copy this file to ".env" and fill in your values.
# cp .env.example .env

# --- Summaries ---------------------------------------------------------------
# Primary backend; the fallback takes over automatically if the primary fails
# (e.g. API credits run out). Set the fallback empty to disable it.
#   api         -> Anthropic API (pay-as-you-go; needs ANTHROPIC_API_KEY).
#   claude_cli  -> `claude` CLI under your Claude Pro/Max subscription (no API
#                  billing; local-only; requires Claude Code installed + signed in).
SUMMARY_BACKEND=api
SUMMARY_FALLBACK_BACKEND=claude_cli

# Roughly how long each summary should be (words).
SUMMARY_MAX_WORDS=60

# -- api backend --
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# Haiku 4.5 is cheap + fast; "claude-sonnet-4-6" is richer but costs more.
ANTHROPIC_MODEL=claude-haiku-4-5

# -- claude_cli backend (also used as the fallback above) --
# Model alias; "haiku" keeps it cheap/fast. Empty = your subscription's default.
CLAUDE_CLI_MODEL=haiku
# Path to the claude binary if it's not on PATH.
# CLAUDE_CLI_PATH=claude

# --- Semantic search ---------------------------------------------------------
# The search bar blends keyword (BM25) results with semantic (embedding)
# results. Embeddings are generated locally with sentence-transformers — no API,
# no extra key. Leave these at their defaults unless you want to experiment.
#   ARXIV_SEMANTIC=0     -> turn semantic off; search stays keyword-only.
#   ARXIV_EMBED_MODEL    -> any sentence-transformers model. If you change it to
#                           one with a different vector size, set ARXIV_EMBED_DIM
#                           to match and re-embed: `python backend/run.py embed --rebuild`.
ARXIV_SEMANTIC=1
ARXIV_EMBED_MODEL=all-MiniLM-L6-v2
ARXIV_EMBED_DIM=384

# --- arXiv -------------------------------------------------------------------
# INITIAL categories to follow, comma-separated. This is only a seed: once the
# app runs you manage the set in the dashboard ("Categories" button), and your
# choice is saved in the database. Full list: https://arxiv.org/category_taxonomy
ARXIV_CATEGORIES=cs.LG,cs.AI,cs.CL,cs.CV

# --- Server ------------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Set to 1/true for verbose logging: full tracebacks on failed pulls plus the
# arXiv client's per-page request chatter. Leave unset for normal (INFO) logs.
ARXIV_DEBUG=

# Copy this file to ".env" and fill in your values.
# cp .env.example .env
#
# Everything here is OPTIONAL — Atlas runs with no keys (just rate-limited on
# Semantic Scholar, and the AI teacher needs a Claude backend).

# --- Semantic Scholar --------------------------------------------------------
# The academic-graph backbone. A free key lifts the tight unauthenticated rate
# limit — strongly recommended. Get one at:
# https://www.semanticscholar.org/product/api
S2_API_KEY=

# --- AI teacher (Claude backend) ---------------------------------------------
# Which Claude backend the lecture + Q&A use. Primary is tried first; the
# fallback takes over if it fails to start (e.g. missing key).
#   api         -> Anthropic API (pay-as-you-go; needs ANTHROPIC_API_KEY).
#   claude_cli  -> `claude` CLI under your Claude Pro/Max subscription (no API
#                  billing; local-only; requires Claude Code installed + signed in).
# TEACHER_BACKEND / TEACHER_FALLBACK_BACKEND default to these; set them to
# override the teacher independently.
SUMMARY_BACKEND=api
SUMMARY_FALLBACK_BACKEND=claude_cli
# TEACHER_BACKEND=claude_cli

# -- api backend --
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
# The model the teacher narrates with (Sonnet is a good default).
# TEACHER_MODEL=claude-sonnet-4-6

# -- claude_cli backend --
# Path to the claude binary if it's not on PATH.
# CLAUDE_CLI_PATH=claude
# Model alias for the CLI teacher.
# TEACHER_CLI_MODEL=sonnet

# --- Bring-your-own sources: local embeddings (Phase 3d) ---------------------
# Uploaded PDFs / pages are embedded LOCALLY (no key; text never leaves the box).
# Default is all-MiniLM-L6-v2 (384-dim). To swap in the stronger bge-small (also
# 384-dim, so ARXIV_EMBED_DIM stays 384) uncomment both lines and RE-INGEST your
# sources (existing vectors were made by the old model):
# ARXIV_EMBED_MODEL=BAAI/bge-small-en-v1.5
# ARXIV_EMBED_QUERY_PREFIX=Represent this sentence for searching relevant passages:

# --- Server ------------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Set to 1/true for verbose (DEBUG) logging. Leave unset for normal (INFO) logs.
ARXIV_DEBUG=

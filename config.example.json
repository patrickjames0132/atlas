{
  "storage": {
    "data_dir": "data",
    "s2": {
      "raw": null,
      "parquet": null
    }
  },
  "providers": {
    "s2": {
      "api_key": "",
      "graph_url": "https://api.semanticscholar.org/graph/v1",
      "recs_url": "https://api.semanticscholar.org/recommendations/v1",
      "timeout": 30,
      "min_interval": 1.1
    },
    "openalex": {
      "api_key": "",
      "mailto": "you@example.com",
      "base_url": "https://api.openalex.org",
      "timeout": 30,
      "min_interval": 0.1
    }
  },
  "graph": {
    "default_provider": "s2",
    "ref_limit": 100,
    "cite_limit": 150,
    "adaptive_cite_limit": true,
    "latest_limit": 150,
    "similar_limit": 60,
    "latest_band_years": 5,
    "adaptive_latest_band": true,
    "latest_per_year": 50,
    "recs_pool": "all-cs",
    "cache_ttl": 86400
  },
  "sources": {
    "semantic_enabled": true,
    "embedding": {
      "model": "sentence-transformers/all-MiniLM-L6-v2",
      "dim": 384,
      "query_prefix": "",
      "device": "auto"
    },
    "chunking": {
      "chars": 900,
      "overlap": 150
    },
    "retrieval": {
      "search_k": 6,
      "hybrid": true,
      "rrf_k": 60,
      "chat_k": 8
    }
  },
  "pdf": {
    "max_bytes": 26214400,
    "timeout": 60,
    "cache_files": 200,
    "max_floats": 12,
    "render_dpi": 150
  },
  "server": {
    "host": "127.0.0.1",
    "port": 5000,
    "debug": false,
    "history_turns": 8
  },
  "llm": {
    "providers": {
      "anthropic": {
        "api_key": "sk-ant-..."
      }
    },
    "agents": [
      {
        "id": "query_analyst",
        "model": "anthropic:claude-haiku-4-5",
        "extras": {}
      },
      {
        "id": "summarizer",
        "model": "anthropic:claude-haiku-4-5",
        "extras": {}
      },
      {
        "id": "librarian",
        "model": "anthropic:claude-sonnet-4-6",
        "extras": {}
      },
      {
        "id": "lecturer",
        "model": "anthropic:claude-sonnet-4-6",
        "extras": {
          "frontier_window_months": 60,
          "min_beats": 7,
          "max_beats": 12
        }
      },
      {
        "id": "researcher",
        "model": "anthropic:claude-sonnet-4-6",
        "extras": {
          "max_steps": 12,
          "full_reads": 4,
          "summary_reads": 12,
          "hops": 5,
          "expand_limit": 8,
          "searches": 3,
          "search_limit": 8,
          "source_searches": 5,
          "figures": 3,
          "fulltext_max_chars": 8000
        }
      }
    ]
  }
}
